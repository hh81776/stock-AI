<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StockAI — AI 股票分析</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
:root{--bg:#0d0f14;--bg2:#13161e;--bg3:#1a1e28;--border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.13);--text:#e8eaf0;--text2:#8b90a0;--text3:#555a6a;--accent:#4f8ef7;--accent2:#3d7be8;--green:#34d399;--red:#f87171;--amber:#fbbf24;--teal:#2dd4bf;--radius:10px;--radius-lg:14px}
*{box-sizing:border-box;margin:0;padding:0}
html{background:var(--bg);color:var(--text);font-family:'Outfit',sans-serif}
body{min-height:100vh}
.shell{display:grid;grid-template-columns:240px 1fr;min-height:100vh}
.sidebar{background:var(--bg2);border-right:1px solid var(--border);padding:20px 14px;display:flex;flex-direction:column;gap:6px;position:sticky;top:0;height:100vh;overflow-y:auto}
.main{padding:28px 32px;overflow-y:auto}
.brand{display:flex;align-items:center;gap:10px;padding:8px;margin-bottom:20px}
.brand-icon{width:36px;height:36px;background:var(--accent);border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.brand-name{font-size:15px;font-weight:600;letter-spacing:-.01em}
.brand-sub{font-size:11px;color:var(--text2)}
.nav-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;color:var(--text3);padding:4px 8px;margin-top:10px}
.nav-item{display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:var(--radius);font-size:13px;color:var(--text2);cursor:pointer;transition:all .15s}
.nav-item:hover{background:var(--bg3);color:var(--text)}
.nav-item.active{background:rgba(79,142,247,.15);color:var(--accent)}
.wl-section{margin-top:auto;padding-top:16px;border-top:1px solid var(--border)}
.wl-title{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:8px;padding:0 4px}
.wl-item{display:flex;justify-content:space-between;align-items:center;padding:8px 6px;border-radius:8px;cursor:pointer;transition:background .15s}
.wl-item:hover{background:var(--bg3)}
.wl-sym{font-weight:600;font-family:'DM Mono',monospace;font-size:13px;color:var(--text)}
.wl-badge{font-size:10px;padding:2px 6px;border-radius:6px;font-weight:500;background:rgba(79,142,247,.15);color:var(--accent)}
.page-title{font-size:22px;font-weight:600;margin-bottom:4px;letter-spacing:-.02em}
.page-sub{font-size:13px;color:var(--text2);margin-bottom:18px}
.search-row{display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap}
.search-input{flex:1;min-width:200px;background:var(--bg2);border:1px solid var(--border2);border-radius:var(--radius);padding:0 16px;height:46px;font-size:15px;color:var(--text);font-family:'DM Mono',monospace;letter-spacing:.06em;text-transform:uppercase;transition:border .2s}
.search-input:focus{outline:none;border-color:var(--accent)}
.search-input::placeholder{color:var(--text3);font-family:'Outfit',sans-serif;text-transform:none;letter-spacing:0;font-size:13px}
.btn-search{height:46px;padding:0 24px;background:var(--accent);border:none;border-radius:var(--radius);color:#fff;font-size:14px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:7px;transition:background .15s,transform .1s;white-space:nowrap}
.btn-search:hover{background:var(--accent2)}
.btn-search:active{transform:scale(.97)}
.btn-search:disabled{background:var(--bg3);color:var(--text3);cursor:not-allowed}
.chips{display:flex;gap:6px;flex-wrap:wrap}
.chip{font-size:12px;padding:6px 13px;border-radius:20px;background:var(--bg2);color:var(--text2);cursor:pointer;border:1px solid var(--border);transition:all .15s;font-family:'DM Mono',monospace}
.chip:hover{border-color:var(--border2);color:var(--text)}
.chip.active{background:rgba(79,142,247,.2);border-color:var(--accent);color:var(--accent)}
.status-bar{display:flex;align-items:center;gap:8px;padding:10px 14px;border-radius:var(--radius);background:var(--bg2);border:1px solid var(--border);font-size:13px;color:var(--text2);margin:16px 0}
.sdot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.sdot.idle{background:var(--text3)}.sdot.loading{background:var(--amber);animation:blink 1s infinite}.sdot.done{background:var(--green)}.sdot.error{background:var(--red)}
@keyframes blink{0%,100%{opacity:.3}50%{opacity:1}}
.hero-row{display:flex;align-items:flex-start;justify-content:space-between;flex-wrap:wrap;gap:16px;margin-bottom:22px;padding-bottom:22px;border-bottom:1px solid var(--border)}
.ticker-sym{font-size:30px;font-weight:600;letter-spacing:-.02em;font-family:'DM Mono',monospace}
.exchange-tag{font-size:11px;padding:3px 9px;border-radius:8px;background:rgba(79,142,247,.15);color:var(--accent);font-weight:600}
.company-name{font-size:14px;color:var(--text2);margin-top:3px}
.sector-tag{font-size:11px;color:var(--text3);margin-top:2px}
.price-big{font-size:36px;font-weight:300;letter-spacing:-.03em;font-family:'DM Mono',monospace;line-height:1;text-align:right}
.price-change{font-size:14px;margin-top:4px;text-align:right}
.price-range{font-size:11px;color:var(--text3);margin-top:3px;text-align:right}
.green{color:var(--green)}.red{color:var(--red)}.amber{color:var(--amber)}
.grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:20px}
@media(max-width:860px){.grid-4{grid-template-columns:repeat(2,1fr)}.grid-2{grid-template-columns:1fr}.shell{grid-template-columns:1fr}.sidebar{display:none}}
.mcard{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:14px}
.mcard-label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:var(--text3);margin-bottom:7px}
.mcard-value{font-size:20px;font-weight:500;font-family:'DM Mono',monospace;line-height:1}
.mcard-sub{font-size:11px;color:var(--text2);margin-top:4px}
.scard{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius-lg);padding:18px;margin-bottom:16px}
.scard-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.08em;color:var(--text3);margin-bottom:14px}
.data-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border);font-size:13px}
.data-row:last-child{border-bottom:none}
.data-label{color:var(--text2)}
.data-val{font-weight:500;font-family:'DM Mono',monospace;font-size:12px}
.signals{display:grid;grid-template-columns:1fr 1fr;gap:7px}
.signal-item{display:flex;align-items:flex-start;gap:8px;padding:8px 10px;background:var(--bg3);border-radius:8px;font-size:12px;line-height:1.4}
.sig-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:3px}
.target-track{position:relative;height:8px;background:var(--bg3);border-radius:4px;margin:8px 0}
.target-fill{position:absolute;left:0;top:0;height:100%;border-radius:4px;background:linear-gradient(90deg,var(--accent),var(--teal))}
.target-cursor{position:absolute;top:-4px;width:4px;height:16px;background:#fff;border-radius:2px;transform:translateX(-50%)}
.target-labels{display:flex;justify-content:space-between;font-size:11px;color:var(--text3);font-family:'DM Mono',monospace}
.analyst-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border);font-size:12px}
.analyst-row:last-child{border-bottom:none}
.analyst-firm{width:120px;color:var(--text2);flex-shrink:0}
.analyst-bar-bg{flex:1;height:4px;background:var(--bg3);border-radius:2px;overflow:hidden}
.analyst-bar-fill{height:100%;border-radius:2px;background:var(--accent)}
.analyst-val{width:75px;text-align:right;font-family:'DM Mono',monospace;font-size:12px}
.risk-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border);font-size:12px}
.risk-row:last-child{border-bottom:none}
.risk-label{width:120px;color:var(--text2);flex-shrink:0}
.risk-bg{flex:1;height:5px;background:var(--bg3);border-radius:3px;overflow:hidden}
.risk-fill{height:100%;border-radius:3px}
.risk-level{width:24px;text-align:right;font-size:11px}
.catalyst-list{list-style:none}
.catalyst-list li{display:flex;gap:9px;padding:8px 0;border-bottom:1px solid var(--border);font-size:13px;align-items:flex-start;line-height:1.5}
.catalyst-list li:last-child{border-bottom:none}
.cat-bullet{width:6px;height:6px;border-radius:50%;background:var(--accent);flex-shrink:0;margin-top:6px}
.comp-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
.comp-card{background:var(--bg3);border:1px solid var(--border);border-radius:var(--radius);padding:13px;font-size:12px}
.comp-card.featured{border-color:var(--accent)}
.comp-name{font-size:13px;font-weight:600;margin-bottom:7px}
.comp-row{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid var(--border);color:var(--text2)}
.comp-row:last-child{border-bottom:none}
.comp-row span:last-child{color:var(--text);font-family:'DM Mono',monospace;font-size:11px}
.platform-row{display:flex;align-items:center;gap:10px;padding:5px 0}
.platform-label{width:95px;color:var(--text2);flex-shrink:0;font-size:11px}
.platform-bar-bg{flex:1;height:6px;background:var(--bg3);border-radius:3px;overflow:hidden}
.platform-bar-fill{height:100%;border-radius:3px}
.platform-pct{width:30px;text-align:right;font-family:'DM Mono',monospace;font-size:11px;color:var(--text2)}
.badge{display:inline-block;font-size:11px;padding:2px 7px;border-radius:7px;font-weight:500}
.badge-strong{background:rgba(52,211,153,.15);color:var(--green)}
.badge-buy{background:rgba(79,142,247,.15);color:var(--accent)}
.badge-hold{background:rgba(251,191,36,.15);color:var(--amber)}
.badge-sell{background:rgba(248,113,113,.15);color:var(--red)}
.chart-wrap{position:relative;width:100%;height:190px}
.empty{text-align:center;padding:70px 20px}
.empty-icon{font-size:52px;margin-bottom:14px;opacity:.2}
.empty-title{font-size:20px;font-weight:500;margin-bottom:8px}
.empty-sub{font-size:13px;color:var(--text2)}
@keyframes shimmer{0%{opacity:.4}50%{opacity:.8}100%{opacity:.4}}
.skeleton{background:var(--bg3);border-radius:8px;animation:shimmer 1.5s infinite}
.disclaimer{font-size:11px;color:var(--text3);padding:16px 0;border-top:1px solid var(--border);margin-top:4px;line-height:1.6}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:transparent}::-webkit-scrollbar-thumb{background:var(--bg3);border-radius:3px}
</style>
</head>
<body>
<div class="shell">

<aside class="sidebar">
  <div class="brand">
    <div class="brand-icon">📊</div>
    <div>
      <div class="brand-name">StockAI</div>
      <div class="brand-sub">AI 股票分析平台</div>
    </div>
  </div>
  <div class="nav-label">工具</div>
  <div class="nav-item active">📋&nbsp;&nbsp;總覽 Dashboard</div>
  <div class="nav-item">📈&nbsp;&nbsp;技術分析</div>
  <div class="nav-item">💰&nbsp;&nbsp;財務報表</div>
  <div class="nav-item">🌐&nbsp;&nbsp;競爭分析</div>
  <div class="wl-section">
    <div class="wl-title">快速查詢</div>
    <div class="wl-item" onclick="quickSearch('FTAI')"><span class="wl-sym">FTAI</span><span class="wl-badge">查詢</span></div>
    <div class="wl-item" onclick="quickSearch('2330.TW')"><span class="wl-sym">2330.TW</span><span class="wl-badge">查詢</span></div>
    <div class="wl-item" onclick="quickSearch('NVDA')"><span class="wl-sym">NVDA</span><span class="wl-badge">查詢</span></div>
    <div class="wl-item" onclick="quickSearch('AAPL')"><span class="wl-sym">AAPL</span><span class="wl-badge">查詢</span></div>
    <div class="wl-item" onclick="quickSearch('TSLA')"><span class="wl-sym">TSLA</span><span class="wl-badge">查詢</span></div>
    <div class="wl-item" onclick="quickSearch('META')"><span class="wl-sym">META</span><span class="wl-badge">查詢</span></div>
    <div class="wl-item" onclick="quickSearch('MSFT')"><span class="wl-sym">MSFT</span><span class="wl-badge">查詢</span></div>
    <div class="wl-item" onclick="quickSearch('AMZN')"><span class="wl-sym">AMZN</span><span class="wl-badge">查詢</span></div>
  </div>
</aside>

<main class="main">
  <div class="page-title">股票分析 Dashboard</div>
  <div class="page-sub">輸入任意股票代碼，由 Claude AI 即時生成完整分析報告</div>

  <div class="search-row">
    <input type="text" class="search-input" id="tickerInput" placeholder="輸入股票代碼，例如：AAPL、NVDA、2330.TW" maxlength="12" />
    <button class="btn-search" id="searchBtn" onclick="runAnalysis()">🔍 分析</button>
  </div>
  <div class="chips">
    <span class="chip" onclick="setChip(this,'FTAI')">FTAI</span>
    <span class="chip" onclick="setChip(this,'NVDA')">NVDA</span>
    <span class="chip" onclick="setChip(this,'AAPL')">AAPL</span>
    <span class="chip" onclick="setChip(this,'TSLA')">TSLA</span>
    <span class="chip" onclick="setChip(this,'MSFT')">MSFT</span>
    <span class="chip" onclick="setChip(this,'META')">META</span>
    <span class="chip" onclick="setChip(this,'AMZN')">AMZN</span>
    <span class="chip" onclick="setChip(this,'2330.TW')">2330.TW</span>
    <span class="chip" onclick="setChip(this,'TSM')">TSM</span>
  </div>

  <div class="status-bar">
    <div class="sdot idle" id="sdot"></div>
    <span id="stext">請輸入股票代碼或點選快速選項開始分析</span>
  </div>

  <div id="dashContent">
    <div class="empty">
      <div class="empty-icon">📈</div>
      <div class="empty-title">選擇股票開始分析</div>
      <div class="empty-sub">由 AI 自動搜尋最新資料，生成財務、技術面、競爭分析完整報告</div>
    </div>
  </div>
</main>
</div>

<script>
let currentChart = null;
let isLoading = false;

function setChip(el, ticker) {
  document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tickerInput').value = ticker;
  runAnalysis();
}

function quickSearch(t) {
  document.getElementById('tickerInput').value = t;
  runAnalysis();
}

document.getElementById('tickerInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') runAnalysis();
  setTimeout(() => { e.target.value = e.target.value.toUpperCase(); }, 0);
});

function setStatus(state, text) {
  document.getElementById('sdot').className = 'sdot ' + state;
  document.getElementById('stext').textContent = text;
}

async function runAnalysis() {
  if (isLoading) return;
  const ticker = document.getElementById('tickerInput').value.trim().toUpperCase();
  if (!ticker) return;

  isLoading = true;
  document.getElementById('searchBtn').disabled = true;
  setStatus('loading', `正在分析 ${ticker}，請稍候約 15 秒...`);
  showSkeleton();

  const prompt = `你是專業股票分析師。針對股票 "${ticker}" 提供完整分析，只回傳以下 JSON，不要任何說明或 markdown：

{"ticker":"代碼","exchange":"交易所","company":"公司全名","sector":"產業","currency":"USD或TWD","price":"股價","change":"漲跌額","changePct":"漲跌%","isUp":true,"week52High":"52週高","week52Low":"52週低","marketCap":"市值","peRatio":"本益比","eps":"EPS","dividend":"股息","dividendYield":"殖利率","revenue":"季營收","revenueGrowth":"YoY%","netIncome":"季淨利","grossMargin":"毛利率","operatingMargin":"營業率","netMargin":"淨利率","ebitda":"EBITDA","roe":"ROE","quarterlyRevenue":[5季數字由舊到新],"quarterlyNetIncome":[5季數字],"quarterlyLabels":["Q1 2025","Q2 2025","Q3 2025","Q4 2025","Q1 2026"],"guidance":"全年指引","guidanceGrowth":"成長率","signals":[{"text":"信號","type":"bullish"},{"text":"信號","type":"bullish"},{"text":"信號","type":"bearish"},{"text":"信號","type":"neutral"},{"text":"信號","type":"bearish"},{"text":"信號","type":"neutral"}],"analystRating":"Strong Buy","analystCount":"人數","analysts":[{"firm":"券商","target":"目標價","rating":"Buy","barPct":85},{"firm":"券商2","target":"目標價","rating":"Strong Buy","barPct":100},{"firm":"分析師平均","target":"均價","rating":"Buy","barPct":75},{"firm":"最低目標","target":"低價","rating":"Hold","barPct":40}],"targetLow":"數字","targetAvg":"數字","targetHigh":"數字","targetCurrent":60,"catalysts":["催化劑1","催化劑2","催化劑3","催化劑4"],"risks":[{"label":"風險1","level":80,"severity":"高"},{"label":"風險2","level":60,"severity":"中高"},{"label":"風險3","level":45,"severity":"中"},{"label":"風險4","level":30,"severity":"低中"}],"competitors":[{"name":"自身","ticker":"${ticker}","m1l":"市佔率","m1":"值","m2l":"毛利率","m2":"值","m3":"Strong Buy","featured":true},{"name":"對手1","ticker":"代碼","m1l":"定位","m1":"值","m2l":"優勢","m2":"值","m3":"Buy","featured":false},{"name":"對手2","ticker":"代碼","m1l":"定位","m1":"值","m2l":"劣勢","m2":"值","m3":"Hold","featured":false}],"platforms":[{"label":"業務1","pct":60,"color":"#4f8ef7"},{"label":"業務2","pct":25,"color":"#34d399"},{"label":"業務3","pct":10,"color":"#fbbf24"},{"label":"其他","pct":5,"color":"#a78bfa"}],"nextEarnings":"日期","summary":"2-3句投資評估"}`;

  try {
    const res = await fetch('/api/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-5',
        max_tokens: 2000,
        messages: [{ role: 'user', content: prompt }]
      })
    });

    if (!res.ok) {
      const err = await res.json().catch(() => ({}));
      throw new Error(err.error?.message || `伺服器錯誤 HTTP ${res.status}`);
    }

    const data = await res.json();
    const raw = data.content[0].text.replace(/```json|```/g, '').trim();
    const info = JSON.parse(raw);
    renderDashboard(info);
    setStatus('done', `✓ ${info.company}（${info.ticker}）分析完成 — ${new Date().toLocaleTimeString('zh-TW')}`);
  } catch (err) {
    setStatus('error', '分析失敗：' + err.message);
    document.getElementById('dashContent').innerHTML = `
      <div style="background:rgba(248,113,113,.1);border:1px solid rgba(248,113,113,.3);border-radius:12px;padding:20px;color:var(--red);font-size:14px;line-height:1.8">
        <strong>⚠️ 分析失敗</strong><br><br>${err.message}
      </div>`;
  } finally {
    isLoading = false;
    document.getElementById('searchBtn').disabled = false;
  }
}

function showSkeleton() {
  document.getElementById('dashContent').innerHTML = `<div>${Array(3).fill(`<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px">${Array(4).fill('<div class="skeleton" style="height:70px"></div>').join('')}</div>`).join('')}<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px"><div class="skeleton" style="height:220px"></div><div class="skeleton" style="height:220px"></div></div></div>`;
}

function badge(r) {
  const m = {'Strong Buy':'badge-strong','Buy':'badge-buy','Hold':'badge-hold','Sell':'badge-sell'};
  return `<span class="badge ${m[r]||'badge-hold'}">${r}</span>`;
}

const riskColor = {高:'#f87171',中高:'#fb923c',中:'#fbbf24',低中:'#34d399',低:'#2dd4bf'};
const currSym = c => c==='TWD'?'NT$':c==='USD'?'$':(c+' ');

function renderDashboard(d) {
  if (currentChart) { currentChart.destroy(); currentChart = null; }
  const sym = currSym(d.currency);
  const up = d.isUp;
  const cc = up ? 'green' : 'red';
  const arr = up ? '▲' : '▼';

  document.getElementById('dashContent').innerHTML = `
    <div class="hero-row">
      <div>
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:4px">
          <span class="ticker-sym">${d.ticker}</span>
          <span class="exchange-tag">${d.exchange}</span>
          ${badge(d.analystRating)}
        </div>
        <div class="company-name">${d.company}</div>
        <div class="sector-tag">${d.sector} ・ ${d.analystCount} 位分析師 ・ 下次財報：${d.nextEarnings}</div>
      </div>
      <div>
        <div class="price-big">${sym}${d.price}</div>
        <div class="price-change ${cc}">${arr} ${d.change} (${d.changePct})</div>
        <div class="price-range">52W：${d.week52Low} — ${d.week52High}</div>
      </div>
    </div>

    <div style="background:rgba(79,142,247,.07);border:1px solid rgba(79,142,247,.18);border-radius:12px;padding:13px 16px;margin-bottom:18px;font-size:13px;color:var(--text2);line-height:1.7">${d.summary}</div>

    <div class="grid-4">
      <div class="mcard"><div class="mcard-label">市值</div><div class="mcard-value">${d.marketCap}</div></div>
      <div class="mcard"><div class="mcard-label">季營收</div><div class="mcard-value">${d.revenue}</div><div class="mcard-sub ${cc}">${arr} ${d.revenueGrowth}</div></div>
      <div class="mcard"><div class="mcard-label">季淨利</div><div class="mcard-value">${d.netIncome}</div></div>
      <div class="mcard"><div class="mcard-label">EPS</div><div class="mcard-value">${d.eps}</div></div>
      <div class="mcard"><div class="mcard-label">毛利率</div><div class="mcard-value green">${d.grossMargin}</div></div>
      <div class="mcard"><div class="mcard-label">淨利率</div><div class="mcard-value">${d.netMargin}</div></div>
      <div class="mcard"><div class="mcard-label">ROE</div><div class="mcard-value">${d.roe}</div></div>
      <div class="mcard"><div class="mcard-label">股息殖利率</div><div class="mcard-value">${d.dividendYield}</div><div class="mcard-sub">${d.dividend}/季</div></div>
    </div>

    <div class="grid-2">
      <div class="scard">
        <div class="scard-title">📊 季度財務趨勢</div>
        <div class="chart-wrap"><canvas id="trendChart" role="img" aria-label="季度財務趨勢圖"></canvas></div>
        <div style="display:flex;gap:14px;margin-top:8px;font-size:11px;color:var(--text2)">
          <span><span style="display:inline-block;width:9px;height:9px;background:#4f8ef7;border-radius:2px;margin-right:4px"></span>營收</span>
          <span><span style="display:inline-block;width:9px;height:9px;background:#34d399;border-radius:2px;margin-right:4px"></span>淨利</span>
        </div>
      </div>
      <div class="scard">
        <div class="scard-title">🔍 技術面信號</div>
        <div class="signals">${(d.signals||[]).map(s=>`<div class="signal-item"><div class="sig-dot" style="background:${s.type==='bullish'?'var(--green)':s.type==='bearish'?'var(--red)':'var(--amber)'}"></div>${s.text}</div>`).join('')}</div>
      </div>
    </div>

    <div class="grid-2">
      <div class="scard">
        <div class="scard-title">🎯 全年財務指引</div>
        <div style="font-size:13px;color:var(--text2);margin-bottom:13px;line-height:1.6">${d.guidance}</div>
        <div class="data-row"><span class="data-label">指引成長率</span><span class="data-val green">${d.guidanceGrowth}</span></div>
        <div class="data-row"><span class="data-label">P/E Ratio</span><span class="data-val">${d.peRatio}</span></div>
        <div class="data-row"><span class="data-label">EBITDA</span><span class="data-val">${d.ebitda}</span></div>
        <div class="data-row"><span class="data-label">營業利益率</span><span class="data-val">${d.operatingMargin}</span></div>
      </div>
      <div class="scard">
        <div class="scard-title">🏢 業務結構</div>
        ${(d.platforms||[]).map(p=>`<div class="platform-row"><div class="platform-label">${p.label}</div><div class="platform-bar-bg"><div class="platform-bar-fill" style="width:${p.pct}%;background:${p.color}"></div></div><div class="platform-pct">${p.pct}%</div></div>`).join('')}
      </div>
    </div>

    <div class="scard">
      <div class="scard-title">🎯 分析師目標價</div>
      <div style="margin-bottom:14px">
        <div class="target-labels" style="margin-bottom:5px"><span>低 ${d.targetLow}</span><span>均 ${d.targetAvg}</span><span>高 ${d.targetHigh}</span></div>
        <div class="target-track">
          <div class="target-fill" style="width:${d.targetCurrent||50}%"></div>
          <div class="target-cursor" style="left:${d.targetCurrent||50}%"></div>
        </div>
        <div style="font-size:11px;color:var(--text3);margin-top:4px">白線 = 當前股價位置（${d.targetCurrent}%）</div>
      </div>
      ${(d.analysts||[]).map(a=>`<div class="analyst-row"><span class="analyst-firm">${a.firm}</span><div class="analyst-bar-bg"><div class="analyst-bar-fill" style="width:${a.barPct}%"></div></div><span class="analyst-val">${a.target}</span>${badge(a.rating)}</div>`).join('')}
    </div>

    <div class="grid-2">
      <div class="scard">
        <div class="scard-title">⚡ 成長催化劑</div>
        <ul class="catalyst-list">${(d.catalysts||[]).map(c=>`<li><div class="cat-bullet"></div>${c}</li>`).join('')}</ul>
      </div>
      <div class="scard">
        <div class="scard-title">⚠️ 風險評估</div>
        ${(d.risks||[]).map(r=>`<div class="risk-row"><span class="risk-label">${r.label}</span><div class="risk-bg"><div class="risk-fill" style="width:${r.level}%;background:${riskColor[r.severity]||'#fbbf24'}"></div></div><span class="risk-level" style="color:${riskColor[r.severity]||'#fbbf24'}">${r.severity}</span></div>`).join('')}
      </div>
    </div>

    <div class="scard">
      <div class="scard-title">🌐 競爭對手比較</div>
      <div class="comp-grid">${(d.competitors||[]).map(c=>`<div class="comp-card ${c.featured?'featured':''}"><div class="comp-name">${c.name} <span style="color:var(--text3);font-size:11px">${c.ticker}</span></div><div class="comp-row"><span>${c.m1l}</span><span>${c.m1}</span></div><div class="comp-row"><span>${c.m2l}</span><span>${c.m2}</span></div><div class="comp-row"><span>評級</span><span>${c.m3}</span></div></div>`).join('')}</div>
    </div>

    <div class="disclaimer">⚠️ 本 Dashboard 資料由 AI 自動生成，僅供參考，不構成投資建議。投資決策請自行評估風險並諮詢專業顧問。</div>`;

  setTimeout(() => {
    const ctx = document.getElementById('trendChart');
    if (!ctx) return;
    currentChart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels: d.quarterlyLabels || [],
        datasets: [
          { label: '營收', data: d.quarterlyRevenue || [], backgroundColor: 'rgba(79,142,247,.75)', borderRadius: 4 },
          { label: '淨利', data: d.quarterlyNetIncome || [], backgroundColor: 'rgba(52,211,153,.75)', borderRadius: 4 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          x: { grid: { display: false }, ticks: { color: '#8b90a0', font: { size: 10 } } },
          y: { grid: { color: 'rgba(255,255,255,.04)' }, ticks: { color: '#8b90a0', font: { size: 10 } } }
        }
      }
    });
  }, 80);
}
</script>
</body>
</html>
